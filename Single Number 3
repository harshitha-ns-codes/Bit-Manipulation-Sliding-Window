vector<int> singleNum3(vector<int> &nums)
{
    int XOR = 0;

    for(int i = 0; i < nums.size(); i++)
    {
        XOR ^= nums[i];
    }

    int rightmost = (XOR & Xor-1) & XOR;

    int b1 = 0, b2 = 0;

    for(int i = 0; i < nums.size(); i++)
    {
        if(nums[i] & rightmost)
            b1 ^= nums[i];
        else
            b2 ^= nums[i];
    }

    return {b1, b2};
}
