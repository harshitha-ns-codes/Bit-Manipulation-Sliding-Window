#include <bits/stdc++.h>
using namespace std;

class Solution{
public:

  bool isSet(int n , int i)
  {
    return (n & (1<<i)) != 0;
  }
};

int main()
{
  Solution sol;
  int num =13;
  int index =2;

  if(sol.isSet(num,index))
  {
    cout << "It is a set" << endl;
  }
  else
  {
    cout << "It is not a set" << endl;
}
return 0;
}
    
