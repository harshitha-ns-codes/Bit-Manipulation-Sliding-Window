int longestSubarray(vector<int> &arr, int k)
{
    int l = 0, r = 0;
    int sum = 0;
    int maxLength = 0;

    while(r < n)
    {
        sum = sum + arr[r];

        if(sum > k)
        {
            sum = sum - arr[l];
            l++;
        }

        if(sum <= k)
        {
            maxLength = max(maxLength, r - l + 1);
        }

        r++;
    }

    return maxLength;
}
